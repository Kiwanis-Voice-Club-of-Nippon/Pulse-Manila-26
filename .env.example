# Option A: Gemini API key for AI Studio or API-key-based local runs.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Option B: Vertex AI via local gcloud auth.
# Use this path when developing on a machine authenticated with gcloud.
GOOGLE_CLOUD_PROJECT="arched-science-483612-j6"
GOOGLE_CLOUD_LOCATION="global"
GOOGLE_GENAI_USE_VERTEXAI="True"
GOOGLE_GENAI_MODEL="gemini-2.5-flash"

# URL where the app is hosted, if needed by server-side routes or callbacks.
APP_URL="MY_APP_URL"
